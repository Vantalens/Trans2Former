{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vantalens.github.io/trans2former/plugin-manifest.schema.json",
  "title": "Trans2Former Plugin Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "id",
    "name",
    "version",
    "kind",
    "entry",
    "formats",
    "permissions",
    "resources",
    "integrity",
    "security",
    "fallback"
  ],
  "properties": {
    "schemaVersion": { "const": "trans2former.plugin.v1" },
    "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]{2,63}$" },
    "name": { "type": "string" },
    "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+(-[0-9A-Za-z.-]+)?$" },
    "kind": { "enum": ["format-plugin", "optional-plugin", "local-model-plugin"] },
    "entry": { "type": "string" },
    "formats": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["format", "canRead", "canWrite"],
        "properties": {
          "format": { "type": "string", "pattern": "^[a-z0-9][a-z0-9+-]*$" },
          "canRead": { "type": "boolean" },
          "canWrite": { "type": "boolean" }
        }
      }
    },
    "permissions": {
      "type": "array",
      "items": {
        "enum": ["install-network", "cache-plugin", "process-document", "read-assets", "write-output"]
      }
    },
    "resources": {
      "type": "object",
      "additionalProperties": false,
      "required": ["downloadBytes", "maxRuntimeMemoryMb"],
      "properties": {
        "downloadBytes": { "type": "number", "minimum": 0 },
        "maxRuntimeMemoryMb": { "type": "number", "minimum": 0 }
      }
    },
    "integrity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sha256"],
      "properties": {
        "sha256": { "type": "string", "pattern": "^[a-fA-F0-9]{64}$" }
      }
    },
    "security": {
      "type": "object",
      "additionalProperties": false,
      "required": ["installMode", "processingMode"],
      "properties": {
        "installMode": { "const": "network-only-no-documents" },
        "processingMode": { "const": "local-only-no-network" }
      }
    },
    "install": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "manual": { "type": "boolean" },
        "removable": { "type": "boolean" }
      }
    },
    "fallback": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "message"],
      "properties": {
        "code": { "type": "string" },
        "message": { "type": "string" }
      }
    }
  }
}
