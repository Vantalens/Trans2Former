{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vantalens.github.io/trans2former/document-model.schema.json",
  "title": "Trans2Former DocumentModel",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "title", "sourceFormat", "blocks", "assets", "metadata"],
  "properties": {
    "schemaVersion": {
      "const": "trans2former.document.v1"
    },
    "title": {
      "type": "string"
    },
    "sourceFormat": {
      "type": "string"
    },
    "blocks": {
      "type": "array",
      "items": {
        "oneOf": [
          {
            "type": "object",
            "additionalProperties": false,
            "required": ["type", "id", "sourceSpan", "warnings", "level", "text"],
            "properties": {
              "type": { "const": "heading" },
              "id": { "type": "string" },
              "sourceSpan": { "$ref": "#/$defs/sourceSpan" },
              "warnings": { "$ref": "#/$defs/warnings" },
              "level": { "type": "integer", "minimum": 1, "maximum": 6 },
              "text": { "type": "string" }
            }
          },
          {
            "type": "object",
            "additionalProperties": false,
            "required": ["type", "id", "sourceSpan", "warnings", "text"],
            "properties": {
              "type": { "const": "paragraph" },
              "id": { "type": "string" },
              "sourceSpan": { "$ref": "#/$defs/sourceSpan" },
              "warnings": { "$ref": "#/$defs/warnings" },
              "text": { "type": "string" }
            }
          },
          {
            "type": "object",
            "additionalProperties": false,
            "required": ["type", "id", "sourceSpan", "warnings", "ordered", "items"],
            "properties": {
              "type": { "const": "list" },
              "id": { "type": "string" },
              "sourceSpan": { "$ref": "#/$defs/sourceSpan" },
              "warnings": { "$ref": "#/$defs/warnings" },
              "ordered": { "type": "boolean" },
              "items": {
                "type": "array",
                "items": { "type": "string" }
              },
              "itemMeta": {
                "type": "array",
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["depth", "marker"],
                  "properties": {
                    "depth": { "type": "integer", "minimum": 0 },
                    "marker": { "type": "string" }
                  }
                }
              },
              "chunk": { "type": "object" }
            }
          },
          {
            "type": "object",
            "additionalProperties": false,
            "required": ["type", "id", "sourceSpan", "warnings", "language", "code"],
            "properties": {
              "type": { "const": "code" },
              "id": { "type": "string" },
              "sourceSpan": { "$ref": "#/$defs/sourceSpan" },
              "warnings": { "$ref": "#/$defs/warnings" },
              "language": { "type": "string" },
              "code": { "type": "string" }
            }
          },
          {
            "type": "object",
            "additionalProperties": false,
            "required": ["type", "id", "sourceSpan", "warnings", "headers", "rows"],
            "properties": {
              "type": { "const": "table" },
              "id": { "type": "string" },
              "sourceSpan": { "$ref": "#/$defs/sourceSpan" },
              "warnings": { "$ref": "#/$defs/warnings" },
              "headers": {
                "type": "array",
                "items": { "type": "string" }
              },
              "rows": {
                "type": "array",
                "items": {
                  "type": "array",
                  "items": { "type": "string" }
                }
              },
              "alignments": {
                "type": "array",
                "items": {
                  "enum": ["", "left", "center", "right"]
                }
              },
              "chunk": { "type": "object" }
            }
          },
          {
            "type": "object",
            "additionalProperties": false,
            "required": ["type", "id", "sourceSpan", "warnings", "text"],
            "properties": {
              "type": { "const": "quote" },
              "id": { "type": "string" },
              "sourceSpan": { "$ref": "#/$defs/sourceSpan" },
              "warnings": { "$ref": "#/$defs/warnings" },
              "text": { "type": "string" }
            }
          },
          {
            "type": "object",
            "additionalProperties": false,
            "required": ["type", "id", "sourceSpan", "warnings", "src", "alt", "title"],
            "properties": {
              "type": { "const": "image" },
              "id": { "type": "string" },
              "sourceSpan": { "$ref": "#/$defs/sourceSpan" },
              "warnings": { "$ref": "#/$defs/warnings" },
              "src": { "type": "string" },
              "alt": { "type": "string" },
              "title": { "type": "string" }
            }
          },
          {
            "type": "object",
            "additionalProperties": false,
            "required": ["type", "id", "sourceSpan", "warnings", "assetId", "alt", "title"],
            "properties": {
              "type": { "const": "asset" },
              "id": { "type": "string" },
              "sourceSpan": { "$ref": "#/$defs/sourceSpan" },
              "warnings": { "$ref": "#/$defs/warnings" },
              "assetId": { "type": "string" },
              "alt": { "type": "string" },
              "title": { "type": "string" }
            }
          },
          {
            "type": "object",
            "additionalProperties": false,
            "required": ["type", "id", "sourceSpan", "warnings", "format", "content"],
            "properties": {
              "type": { "const": "raw" },
              "id": { "type": "string" },
              "sourceSpan": { "$ref": "#/$defs/sourceSpan" },
              "warnings": { "$ref": "#/$defs/warnings" },
              "format": { "type": "string" },
              "content": { "type": "string" }
            }
          }
        ]
      }
    },
    "assets": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "name", "mime", "data", "size", "role", "provenance"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "mime": { "type": "string" },
          "data": { "type": "string" },
          "size": { "type": "number" },
          "role": { "type": "string" },
          "provenance": {
            "type": "object",
            "additionalProperties": false,
            "required": ["sourceFormat", "fileName", "sourceSpan", "role"],
            "properties": {
              "sourceFormat": { "type": "string" },
              "fileName": { "type": "string" },
              "sourceSpan": {
                "oneOf": [
                  { "$ref": "#/$defs/sourceSpan" },
                  { "type": "null" }
                ]
              },
              "role": { "type": "string" }
            }
          }
        }
      }
    },
    "metadata": {
      "type": "object",
      "properties": {
        "warnings": { "$ref": "#/$defs/warnings" },
        "conversion": { "type": "object" },
        "qualityReport": { "type": "object" }
      },
      "additionalProperties": true
    }
  },
  "$defs": {
    "sourceSpan": {
      "type": "object",
      "additionalProperties": false,
      "required": ["startLine", "endLine", "startOffset", "endOffset"],
      "properties": {
        "startLine": { "type": ["integer", "null"] },
        "endLine": { "type": ["integer", "null"] },
        "startOffset": { "type": ["integer", "null"] },
        "endOffset": { "type": ["integer", "null"] }
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["severity", "code", "message", "details"],
        "properties": {
          "severity": { "enum": ["info", "lossy", "unsupported", "security", "performance"] },
          "code": { "type": "string" },
          "message": { "type": "string" },
          "details": { "type": "object" }
        }
      }
    }
  }
}
