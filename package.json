{
  "name": "trans2former",
  "version": "2.0.0",
  "description": "Trans2Former: Browser-first multi-format document transformer.",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "web": "node src/server.js",
    "release:prepare": "node scripts/prepare-release.js",
    "desktop:check": "node scripts/desktop-shell-test.js",
    "desktop:dev": "npm exec @tauri-apps/cli -- dev",
    "desktop:build": "npm exec @tauri-apps/cli -- build",
    "test": "node scripts/smoke-test.js && node scripts/conversion-snapshot-test.js && node scripts/browser-smoke-test.js && node scripts/desktop-shell-test.js && node scripts/local-security-test.js && node scripts/resource-budget-test.js && node scripts/plugin-security-test.js && node scripts/p2-responsiveness-test.js && node scripts/p3-plugin-runtime-test.js && node scripts/release-readiness-test.js"
  },
  "keywords": [
    "converter",
    "transformer",
    "markdown",
    "pdf",
    "html",
    "doc-processing",
    "browser"
  ],
  "author": "Trans2Former Team",
  "license": "MIT",
  "dependencies": {
    "express": "^4.21.2"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Vantalens/Trans2Former.git"
  },
  "bugs": {
    "url": "https://github.com/Vantalens/Trans2Former/issues"
  },
  "homepage": "https://github.com/Vantalens/Trans2Former#readme"
}
