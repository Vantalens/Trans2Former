{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Trans2Former",
  "version": "2.3.0",
  "identifier": "com.vantalens.trans2former",
  "build": {
    "beforeDevCommand": "npm start",
    "beforeBuildCommand": "node scripts/prepare-desktop-dist.js",
    "devUrl": "http://localhost:3000",
    "frontendDist": "../desktop-dist"
  },
  "app": {
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'wasm-unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; frame-src 'self' blob:; worker-src 'self' blob:; connect-src 'self'; object-src 'none'; base-uri 'self'"
    },
    "windows": [
      {
        "label": "main",
        "title": "Trans2Former Desktop",
        "width": 1280,
        "height": 820,
        "minWidth": 960,
        "minHeight": 640,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.ico"]
  }
}
